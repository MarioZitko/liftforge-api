model Client {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique

  // Example: extra fields for Client
  dateOfBirth DateTime?
  lookingForCoach Boolean @default(true)
  // Add more client-specific fields here

  // Relation to ClientPrograms
  clientPrograms ClientProgram[] @relation("ClientProgramClient")
  bio String?

  // Relation to Coach (optional, if you want to link to a coach)
  coachId String?
  coach   Coach?   @relation(fields: [coachId], references: [id])
}

model Coach {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique

  // Example: extra fields for Coach
  certification String?
  // Add more coach-specific fields here
  lookingForClients Boolean @default(true)
  bio String?

  // Relation to Clients
  clients Client[]

  // Relation to ClientPrograms (all programs managed by this coach)
  clientPrograms ClientProgram[] @relation("ClientProgramCoach")

  invitations Invitation[]
}

model Program {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  isPublic    Boolean       @default(false) // optional: allow sharing
  clientProgram ClientProgram? 
  trainingBlocks TrainingBlock[]

  createdBy   User?         @relation("ProgramCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?         @relation("ProgramUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

}

model ClientProgram {
id         Int      @id @default(autoincrement())
name      String
client     Client     @relation("ClientProgramClient",fields: [clientId], references: [id])
clientId   String
program    Program  @relation(fields: [programId], references: [id])
programId  Int @unique
startDate  DateTime
endDate DateTime
status     String   // "active", "completed", "draft", etc.

coachId String?
coach   Coach?   @relation("ClientProgramCoach",fields: [coachId], references: [id])
}

model TrainingBlock {
  id          Int          @id @default(autoincrement())
  name        String
  description String
  weeks       TrainingWeek[]
  program     Program?      @relation(fields: [programId], references: [id])
  programId   Int?

  createdBy   User?   @relation("TrainingBlockCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("TrainingBlockUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model TrainingWeek {
  id         Int         @id @default(autoincrement())
  name      String
  number     Int
  blockId    Int
  block      TrainingBlock @relation(fields: [blockId], references: [id])
  trainings  Training[]

  createdBy   User?   @relation("TrainingWeekCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("TrainingWeekUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Training {
  id                Int               @id @default(autoincrement())
  name              String
  date              DateTime
  weekId            Int
  week              TrainingWeek      @relation(fields: [weekId], references: [id])
  trainingExercises TrainingExercise[]

  createdBy   User?   @relation("TrainingCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("TrainingUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model TrainingExercise {
  id               Int       @id @default(autoincrement())
  trainingId       Int
  exerciseId       Int
  sortOrder        Int
  sets             Int
  reps             Int
  weight           Float
  rpePlanned       Float?
  rpeActual        Float?
  estimated1RM     Float?
  intensity        Float?
  percentageOfMax  Float?
  note             String?
  videoUrl         String?
  volumeId    Int     @unique

  volume Volume? @relation("TrainingExerciseVolume")


  training         Training  @relation(fields: [trainingId], references: [id])
  exercise         Exercise  @relation("TrainingExerciseToExercise", fields: [exerciseId], references: [id])

  createdBy   User?   @relation("TrainingExerciseCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("TrainingExerciseUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Exercise {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  tutorialUrl String?
  
  primaryMuscles   String[]
  secondaryMuscles String[]

  trainingExercises TrainingExercise[] @relation("TrainingExerciseToExercise")

  createdBy   User?   @relation("ExerciseCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("ExerciseUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Volume {
  id         Int      @id @default(autoincrement())
  trainingExerciseId Int      @unique

  trainingExercise   TrainingExercise? @relation("TrainingExerciseVolume", fields: [trainingExerciseId], references: [id])

  volumeTotal Float

  createdBy   User?   @relation("VolumeCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("VolumeUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}
