
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  CLIENT
  COACH
  ADMIN
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String
  role          Role      @default(CLIENT)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Self-relations for auditing
  createdBy    User?   @relation("CreatedUsers", fields: [createdById], references: [id])
  createdById  String?
  createdUsers User[]  @relation("CreatedUsers")

  updatedBy    User?   @relation("UpdatedUsers", fields: [updatedById], references: [id])
  updatedById  String?
  updatedUsers User[]  @relation("UpdatedUsers")

  accounts            Account[]
  sessions            Session[]
  verificationTokens  VerificationToken[]
  hashedRefreshToken  String?
  passwordResetTokens PasswordResetToken[]

  // Reverse auditing relations
  createdAccounts Account[] @relation("AccountCreatedBy")
  updatedAccounts Account[] @relation("AccountUpdatedBy")

  createdSessions Session[] @relation("SessionCreatedBy")
  updatedSessions Session[] @relation("SessionUpdatedBy")

  createdVerificationTokens VerificationToken[] @relation("VerificationTokenCreatedBy")
  updatedVerificationTokens VerificationToken[] @relation("VerificationTokenUpdatedBy")

  createdPasswordResetTokens PasswordResetToken[] @relation("PasswordResetTokenCreatedBy")
  updatedPasswordResetTokens PasswordResetToken[] @relation("PasswordResetTokenUpdatedBy")

  programsCreated      Program[]      @relation("ProgramCreatedBy")
  programsUpdated      Program[]      @relation("ProgramUpdatedBy")

  trainingBlocksCreated TrainingBlock[] @relation("TrainingBlockCreatedBy")
  trainingBlocksUpdated TrainingBlock[] @relation("TrainingBlockUpdatedBy")

  trainingWeeksCreated  TrainingWeek[]  @relation("TrainingWeekCreatedBy")
  trainingWeeksUpdated  TrainingWeek[]  @relation("TrainingWeekUpdatedBy")

  trainingsCreated      Training[]      @relation("TrainingCreatedBy")
  trainingsUpdated      Training[]      @relation("TrainingUpdatedBy")

  trainingExercisesCreated TrainingExercise[] @relation("TrainingExerciseCreatedBy")
  trainingExercisesUpdated TrainingExercise[] @relation("TrainingExerciseUpdatedBy")

  exercisesCreated      Exercise[]      @relation("ExerciseCreatedBy")
  exercisesUpdated      Exercise[]      @relation("ExerciseUpdatedBy")

  volumesCreated      Volume[]      @relation("VolumeCreatedBy")
  volumesUpdated      Volume[]      @relation("VolumeUpdatedBy")

  client Client?
  coach  Coach?
}

model Account {
  id                String  @id @default(uuid())
  provider          String
  providerAccountId String
  type              String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdBy   User?   @relation("AccountCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("AccountUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  createdBy   User?   @relation("SessionCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("SessionUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  createdBy   User?   @relation("VerificationTokenCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("VerificationTokenUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  createdBy   User?   @relation("PasswordResetTokenCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("PasswordResetTokenUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}


model Client {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique

  // Example: extra fields for Client
  dateOfBirth DateTime?
  // Add more client-specific fields here

  // Relation to ClientPrograms
  clientPrograms ClientProgram[] @relation("ClientProgramClient")

  // Relation to Coach (optional, if you want to link to a coach)
  coachId String?
  coach   Coach?   @relation(fields: [coachId], references: [id])
}

model Coach {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique

  // Example: extra fields for Coach
  certification String?
  // Add more coach-specific fields here

  // Relation to Clients
  clients Client[]

  // Relation to ClientPrograms (all programs managed by this coach)
  clientPrograms ClientProgram[] @relation("ClientProgramCoach")
}

model Program {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  isPublic    Boolean       @default(false) // optional: allow sharing
  clientProgram ClientProgram? 
  trainingBlocks TrainingBlock[]

  createdBy   User?         @relation("ProgramCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?         @relation("ProgramUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?

}

model ClientProgram {
id         Int      @id @default(autoincrement())
client     Client     @relation("ClientProgramClient",fields: [clientId], references: [id])
clientId   String
program    Program  @relation(fields: [programId], references: [id])
programId  Int @unique
startDate  DateTime
endDate DateTime
status     String   // "active", "completed", "draft", etc.

coachId String?
coach   Coach?   @relation("ClientProgramCoach",fields: [coachId], references: [id])
}

model TrainingBlock {
  id          Int          @id @default(autoincrement())
  description String
  weeks       TrainingWeek[]
  program     Program?      @relation(fields: [programId], references: [id])
  programId   Int?

  createdBy   User?   @relation("TrainingBlockCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("TrainingBlockUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model TrainingWeek {
  id         Int         @id @default(autoincrement())
  number     Int
  blockId    Int
  block      TrainingBlock @relation(fields: [blockId], references: [id])
  trainings  Training[]

  createdBy   User?   @relation("TrainingWeekCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("TrainingWeekUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Training {
  id                Int               @id @default(autoincrement())
  date              DateTime
  weekId            Int
  week              TrainingWeek      @relation(fields: [weekId], references: [id])
  trainingExercises TrainingExercise[]

  createdBy   User?   @relation("TrainingCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("TrainingUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model TrainingExercise {
  id               Int       @id @default(autoincrement())
  trainingId       Int
  exerciseId       Int
  sortOrder        Int
  sets             Int
  reps             Int
  weight           Float
  rpePlanned       Float?
  rpeActual        Float?
  estimated1RM     Float?
  intensity        Float?
  percentageOfMax  Float?
  note             String?
  videoUrl         String?
  volumeId    Int     @unique

  volume Volume? @relation("TrainingExerciseVolume")


  training         Training  @relation(fields: [trainingId], references: [id])
  exercise         Exercise  @relation("TrainingExerciseToExercise", fields: [exerciseId], references: [id])

  createdBy   User?   @relation("TrainingExerciseCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("TrainingExerciseUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Exercise {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  tutorialUrl String?
  
  primaryMuscles   String[]
  secondaryMuscles String[]

  trainingExercises TrainingExercise[] @relation("TrainingExerciseToExercise")

  createdBy   User?   @relation("ExerciseCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("ExerciseUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}

model Volume {
  id         Int      @id @default(autoincrement())
  trainingExerciseId Int      @unique

  trainingExercise   TrainingExercise? @relation("TrainingExerciseVolume", fields: [trainingExerciseId], references: [id])

  volumeTotal Float

  createdBy   User?   @relation("VolumeCreatedBy", fields: [createdById], references: [id])
  createdById String?
  updatedBy   User?   @relation("VolumeUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
}
